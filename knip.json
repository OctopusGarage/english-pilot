{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [],
  "project": ["src/**/*.ts", "tests/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "binaries": "off",
    "duplicates": "off"
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.test.ts"]
  }
}
